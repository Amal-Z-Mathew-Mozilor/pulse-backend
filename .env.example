# Environment variables for Pulse backend.
# Copy to .env locally OR set in Railway's Variables tab.

# ── Required ─────────────────────────────────────────────────────────────────

# Claude API — used by all agents.
ANTHROPIC_API_KEY=sk-ant-api...

# Postgres — use Supabase's Session pooler URL (port 5432) so LISTEN/NOTIFY works.
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-X-region.pooler.supabase.com:5432/postgres

CLAUDE_MODEL=claude-opus-4-7
CLAUDE_QUERY_MODEL=claude-sonnet-4-6

# CORS — comma-separated origins the API will accept browser requests from.
CORS_ORIGINS=https://pulse-frontend-navy.vercel.app,http://localhost:5173

# Auth secrets — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=GENERATE_ME

# Symmetric key encrypting Jira tokens in the DB. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Back this up — losing it makes every stored Jira token unreadable.
PULSE_ENCRYPTION_KEY=GENERATE_ME

# First admin user, seeded on first boot.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
ADMIN_EMAIL=you@yourcompany.com

# Public-facing URLs
PULSE_PUBLIC_BASE_URL=https://pulse-backend.up.railway.app
FRONTEND_URL=https://pulse-frontend-navy.vercel.app
APP_NAME=Pulse

# ── Optional ─────────────────────────────────────────────────────────────────

# Jira fallback credentials — seed the first JiraAccount row on boot.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=

# Resend — verification + reset emails. If unset, emails log to stdout instead.
RESEND_API_KEY=

# Google OAuth client ID — enables "Sign in with Google".
GOOGLE_CLIENT_ID=
